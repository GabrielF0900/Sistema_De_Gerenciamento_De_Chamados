{
  "compilerOptions": {
    "target": "ES2020",                      // Código moderno
    "module": "commonjs",                    // Necessário pro Node.js
    "rootDir": "./src",                      // Pasta de origem
    "outDir": "./dist",                      // Onde vai gerar os .js
    "strict": true,                          // Checagens mais seguras
    "esModuleInterop": true,                 // Importações CJS/ESM
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true                     // Evita erros com libs
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
